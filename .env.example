# Postgres connection string. In production this is Render's managed Postgres
# (Render injects DATABASE_URL automatically if the DB is added from the same
# dashboard). For local dev, `npx prisma dev` (see README) prints one.
DATABASE_URL=

# Session encryption secret for Auth.js. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=

# Public URL the app is served from (e.g. https://tuxdisplay.tuxmat.ai).
# Locally this can stay blank. Used by Auth.js for OAuth callback URLs.
AUTH_URL=

# Microsoft Entra ID (Azure AD) SSO — TuxMat's standard Azure credential trio.
# The OIDC issuer is built from AZURE_TENANT_ID in code, so no issuer URL is
# needed. Leave these unset locally to use the dev sign-in bypass (see README);
# it's automatically disabled the moment AZURE_CLIENT_ID is set, e.g. in prod.
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# Optional: object IDs of two Entra AD security groups for admin/marketing role
# separation. Leave both blank and every signed-in employee is an admin.
ENTRA_ADMIN_GROUP_ID=
ENTRA_MARKETING_GROUP_ID=

# Cloudflare R2 (S3-compatible) bucket for uploaded media.
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
# Public base URL media is served from (R2 public bucket URL or a Cloudflare
# custom domain in front of the bucket) — files are served at "<this>/<key>".
CLOUDFLARE_R2_PUBLIC_URL=
