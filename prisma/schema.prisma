// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MARKETING
  VIEWER
}

enum MediaType {
  IMAGE
  VIDEO
}

enum ContentFit {
  COVER
  CONTAIN
  FILL
}

enum Orientation {
  PORTRAIT
  LANDSCAPE
}

enum CarouselTransition {
  SLIDE
  FADE
}

// Global key/value settings (e.g. the chosen screensaver style). One row per
// key; app-wide, not per-display.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model User {
  id            String   @id @default(cuid())
  entraObjectId String   @unique
  email         String   @unique
  name          String?
  role          Role     @default(VIEWER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  uploadedContent   ContentItem[]
  createdAssignments Assignment[]
}

model Room {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Video-wall carousel: when active, every display in the room rotates its
  // "home" graphic to the next display on a shared, server-timed beat (all
  // screens push and land together). `carouselStartedAt` is the anchor the
  // rotation tick is computed from; null when the carousel is off.
  carouselActive    Boolean   @default(false)
  carouselStartedAt DateTime?
  // How the carousel (and any display's own multi-item playlist) transitions
  // between items in this room: a hard push-slide, or a soft crossfade.
  carouselTransition CarouselTransition @default(SLIDE)

  displays Display[]
}

model Display {
  id                  String   @id @default(cuid())
  slug                String   @unique @default(cuid())
  name                String
  number              Int
  roomId              String
  room                Room     @relation(fields: [roomId], references: [id])
  active              Boolean  @default(true)
  screensaverOverride Boolean?
  contentFit          ContentFit @default(COVER)
  orientation         Orientation @default(PORTRAIT)
  reloadRequestedAt   DateTime? // bumped by the hub's "Refresh" action; the TV reloads on its next content poll when this changes
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  assignments Assignment[]
  heartbeat   Heartbeat?
  device      Device?

  @@index([roomId])
}

model ContentItem {
  id           String    @id @default(cuid())
  title        String
  type         MediaType
  fileUrl      String
  thumbnailUrl String?
  durationSec  Int?
  // Tags an item as shot/cropped for a landscape (16:9) panel vs the default
  // portrait creative. Drives the landscape-only room carousel pool (see
  // lib/display/resolveRoomCarousel.ts) — not otherwise enforced.
  orientation  Orientation @default(PORTRAIT)
  uploadedById String
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignments Assignment[]
}

model Assignment {
  id            String      @id @default(cuid())
  contentItemId String
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id])
  displayId     String
  display       Display     @relation(fields: [displayId], references: [id])

  sortOrder Int @default(0)

  startsAt DateTime?
  endsAt   DateTime?

  daypartStart String?
  daypartEnd   String?

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([displayId])
  @@index([contentItemId])
}

model Heartbeat {
  displayId        String   @id
  display          Display  @relation(fields: [displayId], references: [id])
  currentContentId String?
  reportedAt       DateTime @default(now())
}

// A physical TV browser, identified by a long-lived httpOnly cookie (`token`).
// Enrolled via claim-code pairing: the TV shows a short `pairingCode` + QR while
// unpaired; an admin approves it from the hub, binding it to a Display. After
// that the cookie recognizes the screen permanently — no password on the TV.
model Device {
  id            String    @id @default(cuid())
  token         String    @unique // random secret stored in the TV's httpOnly cookie — the durable identity
  displayId     String?   @unique // which Display this screen shows (null until paired)
  display       Display?  @relation(fields: [displayId], references: [id])
  pairingCode   String?   @unique // short human code shown on the TV while unpaired (e.g. TUX-4F9K)
  codeExpiresAt DateTime?
  label         String? // optional note ("by Colin's desk")
  pairedAt      DateTime?
  lastSeenAt    DateTime?
  createdAt     DateTime  @default(now())
}
